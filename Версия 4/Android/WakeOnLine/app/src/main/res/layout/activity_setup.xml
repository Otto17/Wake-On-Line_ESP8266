<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="@string/setup_title"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#1976D2"/>

        <!-- Подзаголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="32dp"
            android:text="@string/setup_subtitle"
            android:textSize="14sp"
            android:textColor="#888888"/>

        <!-- Поле: адрес -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_label_url"
            android:textSize="13sp"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setup_hint_url"
            android:inputType="textUri"
            android:autofillHints="@string/setup_hint_url"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:textSize="15sp"
            android:textColor="#111111"
            android:textColorHint="#AAAAAA"
            android:singleLine="true"
            android:layout_marginBottom="16dp"/>

        <!-- Поле: логин -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_label_login"
            android:textSize="13sp"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etLogin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setup_hint_login"
            android:inputType="text"
            android:autofillHints="username"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:textSize="15sp"
            android:textColor="#111111"
            android:textColorHint="#AAAAAA"
            android:singleLine="true"
            android:layout_marginBottom="16dp"/>

        <!-- Поле: пароль -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_label_password"
            android:textSize="13sp"
            android:textColor="#333333"
            android:layout_marginBottom="4dp"/>

        <EditText
            android:id="@+id/etPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/setup_hint_password"
            android:inputType="textPassword"
            android:autofillHints="password"
            android:background="@drawable/input_background"
            android:padding="14dp"
            android:textSize="15sp"
            android:textColor="#111111"
            android:textColorHint="#AAAAAA"
            android:singleLine="true"
            android:layout_marginBottom="24dp"/>

        <!-- Кнопка -->
        <Button
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="@string/setup_btn_save"
            android:textSize="15sp"
            android:backgroundTint="#1976D2"
            android:layout_marginBottom="20dp"/>

        <!-- Подсказка -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/setup_tip"
            android:textSize="12sp"
            android:textColor="#AAAAAA"
            android:lineSpacingExtra="3dp"
            android:gravity="center"/>

    </LinearLayout>

</ScrollView>